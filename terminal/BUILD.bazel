        "text-editor-basic-integration-test-release": {
            "target_server": ":text-editor-server",
            "tags": ["opt_mode"],
        },
    },
    server = "//terminal/integration:exec",
    test = "tests/integration-test-text-editor-basic.spec.mjs",
