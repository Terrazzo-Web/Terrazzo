load("//bazel:rust_rules.bzl", "rust_rules")

package(default_visibility = ["//visibility:public"])

rust_rules(
    name = "integration",
    crate_name = "terrazzo_integration_tests",
    deps = ["//utils/nameth/nameth"],
)

rust_rules(
    name = "exec",
    all_crate_deps = False,
    crate_name = "terrazzo_terminal_test_server",
    crate_root = "src/exec.rs",
    generate_tests = False,
    rule = "binary",
    deps = [":integration"],
)
