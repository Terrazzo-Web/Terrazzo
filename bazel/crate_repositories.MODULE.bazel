    repositories = ["crates_opt_backend"],
)
crates_opt_backend.from_cargo(
    name = "crates_opt_backend",
    cargo_lockfile = "//bazel:Cargo.backend.opt.lock",
    manifests = ["//:Cargo.toml"],
)
use_repo(crates_opt_backend, "crates_opt_backend")

crates_opt_frontend = use_extension("@rules_rust//crate_universe:extensions.bzl", "crate")
crates_opt_frontend.spec(
    features = ["browser"],
    package = "server_fn",
    repositories = ["crates_opt_frontend"],
    version = "=0.8.3",
)
crates_opt_frontend.annotation(
    crate = "tracing",
    crate_features = [
        "max_level_info",
        "release_max_level_info",
    ],
    repositories = ["crates_opt_frontend"],
)
crates_opt_frontend.from_cargo(
    name = "crates_opt_frontend",
    cargo_lockfile = "//bazel:Cargo.frontend.opt.lock",
    manifests = ["//:Cargo.toml"],
