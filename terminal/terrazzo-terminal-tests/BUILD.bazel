load("//bazel:rust_rules.bzl", "rust_rules")

package(default_visibility = ["//visibility:public"])

rust_rules(
    name = "terrazzo-terminal-tests",
    crate_name = "terrazzo_terminal_tests",
    crate_root = "src/main.rs",
    rust_srcs = glob(["src/**/*.rs"]),
    deps = [
        "//utils/nameth/nameth",
    ],
    generate_tests = False,
    rule = "binary",
)
