crates_server = use_extension("@rules_rust//crate_universe:extensions.bzl", "crate")
crates_server.annotation(
    crate = "server_fn",
    crate_features = [
        "axum",
        "axum-no-default",
        "browser",
        "generic",
        "ssr",
    ],
    deps = [
        "@crates_client__axum-0.8.8//:axum",
        "@crates_client__http-body-util-0.1.3//:http_body_util",
        "@crates_client__hyper-1.9.0//:hyper",
        "@crates_client__inventory-0.3.24//:inventory",
        "@crates_client__tokio-1.51.1//:tokio",
        "@crates_client__tower-0.5.3//:tower",
        "@crates_client__tower-layer-0.3.3//:tower_layer",
    ],
    repositories = ["crates_server"],
)
crates_server.from_cargo(
    name = "crates_server",
    cargo_lockfile = "//bazel:Cargo.backend.lock",
    manifests = ["//:Cargo.toml"],
)
use_repo(crates_server, "crates_server")

