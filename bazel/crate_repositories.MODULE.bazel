crates = use_extension("@rules_rust//crate_universe:extensions.bzl", "crate")
crates.render_config(
    default_alias_rule_bzl = "//bazel:crate_aliases.bzl",
    default_alias_rule_name = "cfg_alias",
)
crates.from_cargo(
    name = "crates",
    cargo_lockfile = "//:Cargo.lock",
    manifests = ["//:Cargo.toml"],
)
use_repo(crates, "crates")

macro_client = use_extension("@rules_rust//crate_universe:extensions.bzl", "crate")
macro_client.spec(package = "deluxe", version = "=0.5.0", repositories = ["macro_client"])
macro_client.spec(package = "prettyplease", version = "=0.2.37", repositories = ["macro_client"])
macro_client.spec(package = "proc-macro2", version = "=1.0.106", repositories = ["macro_client"])
macro_client.spec(package = "quote", version = "=1.0.45", repositories = ["macro_client"])
macro_client.spec(package = "server_fn_macro", version = "=0.8.10", repositories = ["macro_client"])
macro_client.spec(
    package = "syn",
    version = "=2.0.117",
    features = ["full", "visit-mut"],
    repositories = ["macro_client"],
)
macro_client.from_specs(
    name = "macro_client",
)
use_repo(macro_client, "macro_client")

