load("//bazel:rust_rules.bzl", "rust_rules")

package(default_visibility = ["//visibility:public"])

rust_rules(
    name = "synctex",
    crate_name = "terrazzo_synctex",
    data_dev = [":fixtures"],
    deps = ["//utils/synctex/sys"],
)

filegroup(
    name = "fixtures",
    srcs = glob(["tests/fixtures/**"]),
)
