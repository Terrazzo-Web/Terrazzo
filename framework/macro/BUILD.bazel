load("//bazel:rust_rules.bzl", "rust_rules")

package(default_visibility = ["//visibility:public"])

rust_rules(
    name = "client",
    package_name = "framework/macro",
    assets = ["README.md"],
    crate_features = ["client"],
    crate_name = "terrazzo_macro",
    rule = "proc_macro",
)

rust_rules(
    name = "server",
    package_name = "framework/macro",
    assets = ["README.md"],
    crate_features = ["server"],
    crate_name = "terrazzo_macro",
    rule = "proc_macro",
)
