playwright_matrix_test(
    extra_data = [
        "tests/PlantUML.pdf",
        "tests/text-editor-helpers.mjs",
    ],
    overrides = {
        "text-editor-viewer-integration-test-debug": {
            "target_server": ":text-editor-server-debug",
        },
        "text-editor-viewer-integration-test-release": {
            "target_server": ":text-editor-server",
            "tags": ["opt_mode"],
        },
    },
    server = "//terminal/integration:exec",
    test = "tests/integration-test-text-editor-viewer.spec.mjs",
